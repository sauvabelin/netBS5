{% extends '@NetBSCore/layout/modal.layout.twig' %}

{% block title %}{{ type == 'parents' ? 'Liste Parents' : 'Liste Chefs' }}{% endblock %}

{% block content %}
    <p><strong>{{ emails|length }} adresse(s) email trouvée(s)</strong></p>
    <div class="form-group">
        <textarea class="form-control" rows="8" readonly style="font-size:13px;" id="mailing-emails-textarea">{{ emails|join('; ') }}</textarea>
    </div>
{% endblock %}

{% block footer %}
    <button type="button" data-bs-dismiss="modal" class="btn btn-secondary">Fermer</button>
    <button type="button" class="btn btn-primary" id="mailing-copy-btn" onclick="
        var text = document.getElementById('mailing-emails-textarea').value;
        if (navigator.clipboard) {
            var btn = this;
            navigator.clipboard.writeText(text).then(function() {
                btn.textContent = 'Copié !';
                btn.classList.add('btn-success');
                btn.classList.remove('btn-primary');
                setTimeout(function() { btn.textContent = 'Copier'; btn.classList.add('btn-primary'); btn.classList.remove('btn-success'); }, 2000);
            });
        }
    ">Copier</button>
{% endblock %}
