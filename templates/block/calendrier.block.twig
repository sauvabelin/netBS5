{{ registerJs('https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js') }}

<div id="dashboard-calendar"></div>

{% set calendarScript %}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('dashboard-calendar');
        if (!calendarEl) return;

        var calendar = new FullCalendar.Calendar(calendarEl, {
            locale: 'fr',
            initialView: 'dayGridMonth',
            firstDay: 1,
            height: 600,
            events: "{{ path('sauvabelin.dashboard.calendar_events') }}",
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek'
            },
        });

        calendar.render();
    });
</script>
{% endset %}

{{ registerScript(calendarScript) }}
