
<div class="btn-group dropdown dropup">

    <button type="button" data-toggle="dropdown" class="btn btn-secondary dropdown-toggle">
        Exporter
        <span class="icon-dropdown mdi mdi-chevron-down"></span>
    </button>

    <div role="menu" class="dropdown-menu">
        {% for extension, exporters in extensions %}
            {% if not loop.first %}
                <div class="dropdown-divider"></div>
            {% endif %}
            <div class="dropdown-header">{{ extension }}</div>
            {% for exporter in exporters %}
                {% if exporter.alias starts with 'mailing.' %}
                    <a class="dropdown-item" style="cursor:pointer;" data-mailing="{{ exporter.alias == 'mailing.parents' ? 'parents' : 'chefs' }}">{{ exporter.name }}</a>
                {% else %}
                    <a class="dropdown-item" style="cursor:pointer;" data-exporter="{{ exporter.alias }}">{{ exporter.name }}</a>
                {% endif %}
            {% endfor %}
        {% endfor %}
    </div>
</div>

{% set exportScript %}
    <script type="text/javascript">
        $('[data-exporter]').click(function() {

            var data = {
                itemsClass:     "{{ table.itemClass|toBase64 }}",
                exporterAlias:  $(this).attr("data-exporter"),
                selectedIds:    {{ tableId }}.getSelectedIds()
            };
            PostLink("{{ path('netbs.core.export.export_selected') }}", data);
        });

        $('[data-mailing]').click(function() {
            var type = $(this).attr("data-mailing");
            var selectedIds = {{ tableId }}.getSelectedIds();

            if (selectedIds.length === 0) {
                alert("Veuillez sélectionner au moins un élément.");
                return;
            }

            var payload = JSON.stringify({
                itemsClass: "{{ table.itemClass|toBase64 }}",
                selectedIds: selectedIds,
                type: type
            });

            $.ajax({
                url: "{{ path('netbs.mailing_list.emails') }}",
                method: "POST",
                contentType: "application/json",
                data: payload,
                success: function(result) {
                    var emails = result.emails || [];
                    var count = result.count || 0;
                    var emailText = emails.join("; ");

                    var modalId = "mailingModal_" + Date.now();
                    var modal = $(
                        '<div class="modal fade netbs-modal" id="' + modalId + '" tabindex="-1" role="dialog">' +
                            '<div class="modal-dialog modal-lg" role="document">' +
                                '<div class="modal-content">' +
                                    '<div class="modal-header">' +
                                        '<h5 class="modal-title">' + (type === 'parents' ? 'Liste Parents' : 'Liste Chefs') + '</h5>' +
                                        '<button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>' +
                                    '</div>' +
                                    '<div class="modal-body">' +
                                        '<p><strong>' + count + ' adresse(s) email trouvée(s)</strong></p>' +
                                        '<div class="form-group">' +
                                            '<textarea class="form-control" rows="8" readonly style="font-size:13px;">' + $('<div>').text(emailText).html() + '</textarea>' +
                                        '</div>' +
                                    '</div>' +
                                    '<div class="modal-footer">' +
                                        '<button type="button" class="btn btn-secondary" data-dismiss="modal">Fermer</button>' +
                                        '<button type="button" class="btn btn-primary mailing-copy-btn">Copier</button>' +
                                    '</div>' +
                                '</div>' +
                            '</div>' +
                        '</div>'
                    );

                    modal.find('.mailing-copy-btn').click(function() {
                        var textarea = modal.find('textarea');
                        if (navigator.clipboard) {
                            navigator.clipboard.writeText(textarea.val()).then(function() {
                                modal.find('.mailing-copy-btn').text('Copié !').addClass('btn-success').removeClass('btn-primary');
                                setTimeout(function() {
                                    modal.find('.mailing-copy-btn').text('Copier').addClass('btn-primary').removeClass('btn-success');
                                }, 2000);
                            });
                        } else {
                            textarea.prop('readonly', false).select();
                            document.execCommand('copy');
                            textarea.prop('readonly', true);
                        }
                    });

                    $('body').append(modal);
                    modal.modal('show');
                    modal.on('hidden.bs.modal', function() {
                        modal.remove();
                    });
                },
                error: function() {
                    alert("Erreur lors de la récupération des emails.");
                }
            });
        });
    </script>
{% endset %}

{{ registerScript(exportScript) }}

{{ registerJs(asset('bundles/netbscore/js/post_link.js')) }}
