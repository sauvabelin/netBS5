{% if assignModel or markPrint %}
<div class="btn-group dropup">
    <button type="button" data-bs-toggle="dropdown" class="btn btn-secondary ms-1 dropdown-toggle">
        Actions de masse
        <span class="icon-dropdown mdi mdi-chevron-down"></span>
    </button>

    <div role="menu" class="dropdown-menu dropdown-menu-right">
        {% if assignModel %}<a class="dropdown-item" style="cursor:pointer;"
           data-controller="modal"
           data-modal-url-value="{{ path('ovesco.facturation.facture.assign_model_modal') }}"
           data-modal-ids-source-value="{{ tableId }}"
           data-action="click->modal#open">Assigner un modèle de facture</a>{% endif %}
        {% if markPrint %}
        <a class="dropdown-item" style="cursor:pointer;" id="mark-printed-{{ tableId }}">Marquer comme imprimé</a>
        <a class="dropdown-item" style="cursor:pointer;" id="unmark-printed-{{ tableId }}">Marquer comme non-imprimé</a>
        {% endif %}
    </div>
</div>
{% endif %}

<div class="btn-group dropup">
    <button type="button" data-bs-toggle="dropdown" class="btn btn-secondary ms-1 dropdown-toggle">
        Facturation
        <span class="icon-dropdown mdi mdi-chevron-down"></span>
    </button>

    <div role="menu" class="dropdown-menu dropdown-menu-right">
        {% if addCreances %}<a class="dropdown-item" style="cursor:pointer;"
           data-controller="modal"
           data-modal-url-value="{{ path('ovesco.facturation.creance.modal_add_many') }}"
           data-modal-params-value='{{ {"itemsClass": table.itemClass|toBase64}|json_encode }}'
           data-modal-ids-source-value="{{ tableId }}"
           data-action="click->modal#open">Ajouter des créances</a>{% endif %}
        {% if addRappels %}<a class="dropdown-item" style="cursor:pointer;"
           data-controller="modal"
           data-modal-url-value="{{ path('ovesco.facturation.rappel.add_modal') }}"
           data-modal-params-value='{{ {"itemsClass": table.itemClass|toBase64}|json_encode }}'
           data-modal-ids-source-value="{{ tableId }}"
           data-action="click->modal#open">Ajouter des rappels</a>{% endif %}
        {% if generate %}<a class="dropdown-item" style="cursor:pointer;"
           data-controller="modal"
           data-modal-url-value="{{ path('ovesco.facturation.creance.merge') }}"
           data-modal-ids-source-value="{{ tableId }}"
           data-modal-id-field-value="creanceIds"
           data-action="click->modal#open">Fusionner en facture</a>
        <a class="dropdown-item" style="cursor:pointer;"
           data-controller="post-link"
           data-post-link-url-value="{{ path('ovesco.facturation.creance.check_merge') }}"
           data-post-link-ids-source-value="{{ tableId }}"
           data-post-link-id-field-value="creanceIds"
           data-action="click->post-link#submit">Prévisualiser la fusion</a>{% endif %}
    </div>
</div>

<script>
    if (!window._factureModelAutoListener) {
        window._factureModelAutoListener = true;
        document.addEventListener('mouseenter', function(e) {
            if (!e.target.closest) return;
            var badge = e.target.closest('.facture-model-auto');
            if (!badge || badge.dataset.loaded) return;
            badge.dataset.loaded = 'true';
            var factureId = badge.dataset.factureId;
            fetch("{{ path('ovesco.facturation.facture.resolve_model', {id: '__ID__'}) }}".replace('__ID__', factureId))
                .then(function(r) { return r.json(); })
                .then(function(data) { badge.textContent = data.model; });
        }, true);
    }

    function markPrintedAction(ids, url, confirmMsg, successMsg) {
        if (ids.length === 0) { alert('Veuillez sélectionner des factures'); return; }
        if (!confirm(confirmMsg)) return;
        fetch(url, {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded'},
            body: 'ids=' + encodeURIComponent(JSON.stringify(ids))
        }).then(function(r) { return r.json(); })
          .then(function(data) { alert(data.count + ' ' + successMsg); location.reload(); })
          .catch(function() { alert('Erreur lors de la mise à jour'); });
    }

    var markBtn = document.getElementById('mark-printed-{{ tableId }}');
    var unmarkBtn = document.getElementById('unmark-printed-{{ tableId }}');
    if (markBtn) markBtn.addEventListener('click', function() {
        var ids = {{ tableId }}.getSelectedIds();
        markPrintedAction(ids, "{{ path('ovesco.facturation.facture.mark_printed') }}",
            'Marquer ' + ids.length + ' facture(s) comme imprimée(s) ?',
            'facture(s) marquée(s) comme imprimée(s)');
    });
    if (unmarkBtn) unmarkBtn.addEventListener('click', function() {
        var ids = {{ tableId }}.getSelectedIds();
        markPrintedAction(ids, "{{ path('ovesco.facturation.facture.unmark_printed') }}",
            'Marquer ' + ids.length + ' facture(s) comme non-imprimée(s) ?',
            'facture(s) marquée(s) comme non-imprimée(s)');
    });
</script>
