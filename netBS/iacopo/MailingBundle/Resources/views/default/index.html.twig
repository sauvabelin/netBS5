{% extends '@NetBSCore/layout/backend.layout.twig' %}

{% set title %}Listes de diffusion{% endset %}

{% block main %}
    {{ registerJs(asset('bundles/netbscore/js/modal.js')) }}

    <div class="container-fluid">
        {% include '@NetBSCore/includes/header.include.twig' with {
            header: 'Listes de diffusion',
            subHeader: 'Gestion des mailings'
        } %}

        <div class="row">
            <div class="col-12">
                <div class="card card-table">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">Listes de diffusion</h5>
                        <button data-modal data-modal-url="{{ path('iacopo.mailing.create') }}" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Nouveau
                        </button>
                    </div>
                    <div class="card-body">
                        {{ render_list('iacopo.mailing.lists', 'netbs') }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Initialize Bootstrap tooltips
        $(document).ready(function() {
            $('[data-toggle="tooltip"]').tooltip({
                html: true,
                trigger: 'hover',
                container: 'body'
            });
        });

        function toggleListActive(id) {
            const checkbox = document.getElementById('toggle-' + id);
            const label = document.getElementById('label-' + id);

            fetch('{{ path('iacopo.mailing.toggle_active', {id: '__ID__'}) }}'.replace('__ID__', id), {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    label.textContent = data.active ? 'Active' : 'Inactive';
                    label.className = 'badge ' + (data.active ? 'badge-success' : 'badge-secondary');
                } else {
                    checkbox.checked = !checkbox.checked;
                    alert('Erreur lors de la mise à jour');
                }
            });
        }
    </script>
{% endblock %}
