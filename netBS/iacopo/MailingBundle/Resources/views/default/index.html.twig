{% extends '@NetBSCore/layout/backend.layout.twig' %}

{% set title %}Listes de diffusion{% endset %}

{% block main %}
    <div class="container-fluid"
         data-controller="mailing"
         data-mailing-toggle-url-value="{{ path('iacopo.mailing.toggle_active', {id: '__ID__'}) }}"
         data-mailing-recipients-url-value="{{ path('iacopo.mailing.recipients', {id: '__ID__'}) }}">
        {% include '@NetBSCore/includes/header.include.twig' with {
            header: 'Listes de diffusion',
            subHeader: 'Gestion des mailings'
        } %}

        <div class="row">
            <div class="col-12">
                <div class="card card-table">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">Listes de diffusion</h5>
                        <button data-controller="modal" data-modal-url-value="{{ path('iacopo.mailing.create') }}" data-action="click->modal#open" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Nouveau
                        </button>
                    </div>
                    <div class="card-body">
                        {{ render_list('iacopo.mailing.lists', 'netbs') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
