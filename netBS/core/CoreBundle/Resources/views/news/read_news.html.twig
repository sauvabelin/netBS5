{% extends '@NetBSCore/layout/backend.layout.twig' %}

{% block main %}

    {% set newsStyle %}
        <style>
            .channel {
                padding:1em;
                border-radius:5px;
            }

            .channel .card:last-child {
                margin-bottom:0;
            }

            .channel .card .badge {
                font-size:1em;
                float:right;
            }

            .channel {
                background: color-mix(in srgb, var(--channel-color) 50%, white);
            }

            @media (prefers-color-scheme: dark) {
                .channel {
                    background: color-mix(in srgb, var(--channel-color) 30%, #1a1d20);
                }
            }
        </style>
    {% endset %}
    {{ registerStyle(newsStyle) }}

    <div class="container-fluid">
        {% include '@NetBSCore/includes/header.include.twig' with {
            header: 'Dernières news',
            subHeader: "Les news triées selon les channels"
        } %}

        <div class="row">
            {% for channel in channels %}
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="channel" style="--channel-color: {{ channel.color }};"
                     data-controller="news-channel"
                     data-news-channel-total-value="{{ channel.news|length }}"
                     data-news-channel-per-page-value="1">
                    <h3 class="pt-2 pb-3">{{ channel.nom }}</h3>

                    {% for item in channel.news %}
                        <div class="card" data-news-channel-target="item"{% if not loop.first %} style="display:none"{% endif %}>
                            <div class="card-header">
                                <h3 class="card-title">{{ item.titre }}</h3>
                                <h5 class="card-subtitle">{{ item.createdAt|date('d/m/Y') }} - {{ item.user }}
                                    {% if item.pinned %}<span class="badge text-white" style="background-color: {{ channel.color }}">pinned</span>{% endif %}
                                </h5>
                            </div>
                            <div class="card-body">{{ item.contenu|raw }}</div>
                        </div>
                    {% endfor %}

                    {% if channel.news|length > 1 %}
                    <nav>
                        <ul class="pagination mb-0">
                            <li class="page-item"><button class="page-link" data-action="click->news-channel#previous">Précédente</button></li>
                            {% for p in 1..channel.news|length %}
                                <li class="page-item{% if p == 1 %} active{% endif %}">
                                    <button class="page-link"
                                            data-news-channel-target="pageButton"
                                            data-action="click->news-channel#goToPage"
                                            data-news-channel-page-param="{{ p }}">{{ p }}</button>
                                </li>
                            {% endfor %}
                            <li class="page-item"><button class="page-link" data-action="click->news-channel#next">Suivante</button></li>
                        </ul>
                    </nav>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
