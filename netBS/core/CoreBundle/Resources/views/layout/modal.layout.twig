{% set _modal %}

    {% set title %}{% block title %}{% endblock %}{% endset %}

    <div class="modal-dialog {% block widthClass %}custom-width{% endblock %}" {% block modalAttrs %}{% endblock %}>
        <div class="modal-content">
            {% if title %}
                <div class="modal-header">
                    <h5 class="modal-title">{{ title }}</h5>
                    <button type="button" data-bs-dismiss="modal" aria-label="Close" class="btn-close"></button>
                </div>
            {% endif %}

            <div class="modal-body" {% block bodyAttr %}{% endblock %}>
                {% block content %}{% endblock %}
            </div>

            <div class="modal-footer">
                {% block footer %}
                    <button type="button" data-bs-dismiss="modal" class="btn btn-secondary">Fermer</button>
                    <button type="button" data-modal-validate id="validate-modal-btn" class="btn btn-primary">Valider</button>
                {% endblock %}
            </div>
        </div>
    </div>
{% endset %}

<!doctype HTML>

{{ dumpCss() }}

{{ _modal }}

<script type="text/javascript">
    document.querySelectorAll('.modal-dialog form').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            var btn = document.getElementById('validate-modal-btn');
            if (btn) btn.click();
        });
    });
</script>
