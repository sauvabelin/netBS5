<header class="main-header">
    <div class="header-sections">

        <div class="header-section header-search"
             data-controller="global-search"
             data-global-search-url-value="{{ path('netbs.core.ui.global_search') }}">
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" placeholder="Rechercher parmi vos unités"
                       data-global-search-target="input"
                       data-action="input->global-search#search focus->global-search#focusInput">
            </div>
        </div>

        <div class="header-section user-menu-section section-right">
            <div class="dropdown">
                <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    {{ app.user.username }}
                </button>
                <div class="dropdown-menu dropdown-menu-end">
                    {% if app.user.membre %}
                    <a class="dropdown-item" href="{{ path('netbs.fichier.membre.page_membre', {id: app.user.membre.id}) }}">{{ app.user.membre.fullname }}</a>
                    {% endif %}
                    <a class="dropdown-item" href="{{ path('netbs.secure.user.account_page') }}">Mon compte</a>
                    <a class="dropdown-item" href="{{ path('netbs.secure.login.logout') }}">Déconnexion</a>
                </div>
            </div>
        </div>

        <div class="header-section mobile-menu-section d-md-none">
            <button id="mobile-menu-btn" class="btn btn-secondary" data-action="click->mobile#toggle">
                <i class="fas fa-bars"></i>
            </button>
        </div>

    </div>
</header>
