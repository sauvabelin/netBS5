
{% use "bootstrap_4_layout.html.twig" %}

{%- block widget_attributes -%}
    {% set class = attr.class is defined ? attr.class ~ ' input-sm' : 'input-sm' %}
    {% set attr = attr|merge({class: class}) %}
    {{ parent() }}
{%- endblock widget_attributes -%}

{% block switch_row %}
    <div class="form-group">
        {{ block('form_label') }}
        {{ block('switch_widget') }}
    </div>
{% endblock %}

{% block switch_label %}
    {{ block('form_label') }}
{% endblock %}

{% block switch_widget %}
    <div>
        <div class="form-check form-switch">
            <input type="checkbox" class="form-check-input" {{ block('widget_attributes') }}{% if value is defined %} value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %} />
        </div>
    </div>
{% endblock %}

{% block mask_widget %}
    {{ block('form_widget_simple') }}
{% endblock %}

{% block quill_widget %}

    {{ registerCss(asset('bundles/netbscore/lib/quill/quill.snow.css')) }}

    <div data-controller="quill" id="{{ form.vars.id }}">
        {{ block('textarea_widget') }}
    </div>

{% endblock %}



{# select 2 stuff #}
{% block ajax_select2_document_widget %}

    {% set dataCheck = [] %}
    {% if form.vars.multiple %}
        {% for item in form.vars.data %}
            {% set dataCheck = dataCheck|merge([item.id]) %}
        {% endfor %}
    {% elseif form.vars.data %}
        {% set dataCheck = [form.vars.data.id] %}
    {% endif %}

    <div data-controller="select2"
         data-select2-ajax-class-value="{{ form.vars.attr['data-ajax-class'] }}"
         data-select2-null-option-value="{{ form.vars.attr['data-null-option']|default('0') }}"
         data-select2-url-value="{{ path('netbs.core.select2.results') }}"
         style="min-width:200px;width:100%;">
        <select {{ block('widget_attributes') }} {% if form.vars.multiple %}multiple="multiple"{% endif %} style="width:100%;">
            {% for option in form.vars.base_choices %}
                <option {% if option.value in dataCheck %}selected{% endif %} value="{{ option.value }}">{{ option.label }}</option>
            {% endfor %}
        </select>
    </div>

{% endblock %}

{% block select2_document_widget %}
    {{ block('select2_widget') }}
{% endblock %}

{% block select2_widget %}
    {{ block('select2') }}
{% endblock %}

{% block select2 %}
    <div data-controller="select2" style="min-width:200px;width:100%;">
        {{ block('choice_widget') }}
    </div>
{% endblock %}

{# datepicker #}
{% block datepicker_widget %}
    {{ block('form_widget_simple') }}
{% endblock %}


{# daterange #}
{% block daterange_widget %}
    <div>
        <div class="input-daterange input-group d-flex align-items-center">
            <div class="flex-grow-1">
                {{ form_row(form.biggerThan) }}
            </div>
            <span class="input-group-text ms-3 me-3"><i class="fas fa-chevron-right"></i></span>
            <div class="flex-grow-1">
                {{ form_row(form.lowerThan) }}
            </div>
        </div>
    </div>
{% endblock %}
