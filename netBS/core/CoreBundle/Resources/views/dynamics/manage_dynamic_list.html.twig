{% extends '@NetBSCore/layout/backend.layout.twig' %}

{% form_theme form '@NetBSCore/form/xeditable.theme.twig' %}

{% block main %}

    <div class="container-fluid">

        <div class="row">

            <div class="col-12 col-md-3">

                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title">{{ list.name }}</h5>
                        <h6 class="card-subtitle">{{ list.items|length }} élément(s)</h6>
                    </div>
                    {% if app.token.user in list.shares and app.token.user != list.owner %}
                        <div class="card-body">
                            Cette liste est partagée avec vous, ainsi vous ne pouvez pas changer ses paramètres.<br/><br/>
                            <b>Propriétaire: {{ list.owner }}</b>
                        </div>
                    {% else %}
                        <div class="card-body">
                            <form class="form-horizontal">
                                {{ form_row(form.name) }}
                            </form>
                        </div>
                        <div class="card-footer">
                            <div role="group" class="btn-group btn-group-justified">
                                <a href="{{ path('netbs.core.dynamics_list.remove_list', {id: list.id}) }}" class="btn btn-secondary" data-turbo-confirm="Etes-vous sûr de vouloir supprimer cette liste ? C'est IRREVERSIBLE!" data-turbo-method="post">Supprimer cette liste</a>
                            </div>
                        </div>
                    {% endif %}
                </div>

                {% if app.token.user not in list.shares and app.token.user == list.owner %}
                    <div class="card card-table">
                        <div class="card-header">
                            <h5 class="card-title">Partages</h5>
                            <h6 class="card-subtitle">Partagée avec {{ list.shares|length }} utilisateurs</h6>
                        </div>
                        <div class="card-body">
                            <table class="table table-bordered">
                                <thead>
                                <tr>
                                    <th>Utilisateur</th>
                                    <th></th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for user in list.shares %}
                                    <tr>
                                        <td>{{ user }}</td>
                                        <td>
                                            <a href="{{ path('netbs.core.dynamics_list.remove_share', { id: list.id }) }}?userid={{ user.id }}" class="btn btn-xs btn-danger" data-bs-toggle="tooltip" title="Retirer le partage" data-turbo-method="post"><i class="fas fa-sm fa-times" aria-hidden="true"></i></a>
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        <div class="card-footer">
                            <div role="group" class="btn-group btn-group-justified">
                                <button class="btn btn-secondary" data-controller="modal" data-modal-url-value="{{ path('netbs.core.dynamic_list.modal_add_share', {id: list.id}) }}" data-action="click->modal#open">Partager avec quelqu'un</button>
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>

            <div class="col-12 col-md-9">
                <div class="card card-table">
                    <div class="card-header">
                        <h5 class="card-title">Contenu</h5>
                    </div>

                    <div class="card-body">
                        {{ render_list(model, 'netbs', {listId: list.id}) }}
                    </div>
                </div>
            </div>

        </div>

    </div>

{% endblock %}