
<div class="btn-group btn-hspace dropup">
    <button type="button" class="btn btn-primary"
            data-controller="post-link"
            data-post-link-url-value="{{ path('netbs.core.changelog.approve') }}"
            data-post-link-ids-source-value="{{ event.tableId }}"
            data-action="click->post-link#submit">Approuver les modifications</button>
</div>

<div class="modal fade colored-header colored-header-primary netbs-modal" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" data-bs-dismiss="modal" aria-label="Close" class="btn-close"></button>
                <h3 class="modal-title">Modification</h3>
            </div>

            <div class="modal-body" id="_change_modal_body"></div>
        </div>
    </div>
</div>

<script type="text/javascript">
    document.querySelectorAll('#{{ event.tableId }} td').forEach(function(td) {
        td.addEventListener('click', function(e) {
            if (e.target.tagName === 'LABEL' || e.target.tagName === 'INPUT') return;
            var tr = this.parentElement;
            var id = tr.getAttribute('data-id');
            document.querySelectorAll('#{{ event.tableId }} tr').forEach(function(r) { r.classList.remove('active'); });
            tr.classList.add('active');
            fetch('{{ path('netbs.core.changelog.preview_change') }}?logId=' + id)
                .then(function(r) { return r.text(); })
                .then(function(html) { document.getElementById('_modif_details').innerHTML = html; });
        });
    });
</script>
