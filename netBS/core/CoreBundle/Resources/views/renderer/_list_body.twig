{#
    Shared table body for server-paginated lists. The outer wrapper (turbo-frame or div)
    and Stimulus controller binding are provided by the caller.

    Variables:
      - controllerName: Stimulus controller key driving pagination/search (e.g. 'ajax-list')
      - rows: current page of rows ({id, cells})
      - headers: column header strings
      - tableId: unique table identifier
      - page, amount, search, totalItems: pagination state
      - hasSearch: whether the search box is shown
      - hasSelection: whether to render checkbox column + select-all
#}

{% set totalPages = amount > 0 ? ((totalItems - 1) / amount)|round(0, 'floor') : 0 %}
{% set totalPages = totalPages < 0 ? 0 : totalPages %}
{% set firstItem = totalItems == 0 ? 0 : page * amount + 1 %}
{% set lastItem  = totalItems == 0 ? 0 : ((page * amount + amount) > totalItems ? totalItems : (page * amount + amount)) %}

<div class="position-relative">
    {# Top: amount selector + search #}
    <div class="row px-3 pt-3">
        <div class="col-sm-12 col-md-6">
            <div class="dataTables_length">
                <label class="d-flex align-items-center">
                    Show
                    <select class="form-control form-control-sm mx-1" style="width:75px"
                            data-{{ controllerName }}-target="amount"
                            data-action="change->{{ controllerName }}#changeAmount">
                        {% for opt in [10, 25, 50, 100] %}
                            <option value="{{ opt }}" {{ amount == opt ? 'selected' : '' }}>{{ opt }}</option>
                        {% endfor %}
                    </select> entries
                </label>
            </div>
        </div>
        <div class="col-sm-12 col-md-6 d-flex justify-content-end">
            {% if hasSearch %}
                <div class="dataTables_filter">
                    <label class="d-flex align-items-center">Search:
                        <input type="search" class="ms-1 form-control form-control-sm" placeholder=""
                               value="{{ search }}"
                               data-{{ controllerName }}-target="search"
                               data-action="input->{{ controllerName }}#searchChanged">
                    </label>
                </div>
            {% endif %}
        </div>
    </div>

    {# Table #}
    <table id="{{ tableId }}" class="table table-hover table-responsive-md table-striped table-fw-widget" style="margin:0 !important;">
        <thead>
            <tr>
                {% if hasSelection %}
                    <th data-orderDataType="checkbox" style="width:30px;">
                        <div class="form-check">
                            <input id="{{ tableId }}_main_cb" class="form-check-input" type="checkbox"
                                   data-checkbox-select-target="selectAll"
                                   data-action="change->checkbox-select#toggleAll">
                            <label class="form-check-label" for="{{ tableId }}_main_cb"></label>
                        </div>
                    </th>
                {% endif %}
                {% for header in headers %}
                    <th>{{ header }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody data-{{ controllerName }}-target="tbody">
            {% include '@NetBSCore/renderer/_list_rows.twig' with {
                rows: rows,
                tableId: tableId,
                hasSelection: hasSelection,
            } only %}
        </tbody>
    </table>

    {# Bottom: info + pagination #}
    <div class="row px-3 pt-3">
        <div class="col-sm-12 col-md-5">
            <div class="dataTables_info" data-{{ controllerName }}-target="info">Showing {{ firstItem }} to {{ lastItem }} of {{ totalItems }} entries</div>
        </div>
        <div class="col-sm-12 col-md-7 d-flex justify-content-end">
            <div class="dataTables_paginate paging_simple_numbers">
                <ul class="pagination" data-{{ controllerName }}-target="pagination">
                    <li class="paginate_button page-item previous {{ page == 0 ? 'disabled' : '' }}">
                        <a href="#" class="page-link" data-action="click->{{ controllerName }}#goToPage" data-page="{{ page - 1 }}">Previous</a>
                    </li>

                    {% if totalPages < 5 %}
                        {% for i in 0..totalPages %}
                            <li class="paginate_button page-item {{ i == page ? 'active' : '' }}">
                                <a href="#" class="page-link" data-action="click->{{ controllerName }}#goToPage" data-page="{{ i }}">{{ i + 1 }}</a>
                            </li>
                        {% endfor %}
                    {% elseif page == 0 or page == 1 %}
                        {% for i in [0, 1, 2, totalPages] %}
                            <li class="paginate_button page-item {{ i == page ? 'active' : '' }}">
                                <a href="#" class="page-link" data-action="click->{{ controllerName }}#goToPage" data-page="{{ i }}">{{ i + 1 }}</a>
                            </li>
                        {% endfor %}
                    {% elseif page == totalPages or page == totalPages - 1 %}
                        {% for i in [totalPages - 3, totalPages - 2, totalPages - 1, totalPages] %}
                            <li class="paginate_button page-item {{ i == page ? 'active' : '' }}">
                                <a href="#" class="page-link" data-action="click->{{ controllerName }}#goToPage" data-page="{{ i }}">{{ i + 1 }}</a>
                            </li>
                        {% endfor %}
                    {% else %}
                        {% for i in [0, page - 1, page, page + 1, totalPages] %}
                            <li class="paginate_button page-item {{ i == page ? 'active' : '' }}">
                                <a href="#" class="page-link" data-action="click->{{ controllerName }}#goToPage" data-page="{{ i }}">{{ i + 1 }}</a>
                            </li>
                        {% endfor %}
                    {% endif %}

                    <li class="paginate_button page-item next {{ page >= totalPages ? 'disabled' : '' }}">
                        <a href="#" class="page-link" data-action="click->{{ controllerName }}#goToPage" data-page="{{ page + 1 }}">Next</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
