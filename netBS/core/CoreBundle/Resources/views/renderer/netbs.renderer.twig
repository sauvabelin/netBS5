{#
    Renderer for complex-search-result lists. All matching rows are server-rendered
    once; client_list_controller paginates and text-filters them in the browser.
#}
<div id="netbs-renderer-{{ tableId }}" class="netbs-renderer position-relative" style="border:1px solid #eee"
     data-controller="checkbox-select client-list">

    {% include '@NetBSCore/renderer/_list_body.twig' with {
        controllerName: 'client-list',
        rows: rows,
        headers: headers,
        tableId: tableId,
        page: page,
        amount: amount,
        search: search,
        totalItems: totalItems,
        hasSearch: hasSearch,
        hasSelection: true,
    } %}

    {% if toolbar.items|length > 0 %}
    <div class="netbs-toolbar dropup">
        <div class="row pb-3 px-3">
            <div class="col-md-6">
                {% for item in toolbar.items('left') %}
                    {{ item.render()|raw }}
                {% endfor %}
            </div>

            <div class="col-md-6 d-flex justify-content-end">
                {% for item in toolbar.items('right') %}
                    {{ item.render()|raw }}
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

</div>

<script type="text/javascript">
    var {{ tableId }} = {
        getSelectedIds: function() {
            var frameEl = document.getElementById('netbs-renderer-{{ tableId }}');
            if (!frameEl) return [];
            var app = window.Stimulus;

            // 1. Whatever the user explicitly checked wins
            var selected = [];
            if (app) {
                var cbCtrl = app.getControllerForElementAndIdentifier(frameEl, 'checkbox-select');
                if (cbCtrl) selected = cbCtrl.selectedIds;
            }
            if (!selected.length) {
                selected = Array.from(frameEl.querySelectorAll('[data-checkbox-select-target="checkbox"]:checked'))
                    .map(function(cb) { return parseInt(cb.value, 10); });
            }
            if (selected.length > 0) return selected;

            // 2. Nothing checked → fall back to every row matching the current search filter
            if (app) {
                var clCtrl = app.getControllerForElementAndIdentifier(frameEl, 'client-list');
                if (clCtrl && typeof clCtrl.getFilteredIds === 'function') {
                    return clCtrl.getFilteredIds();
                }
            }
            return [];
        }
    };
</script>
