
<div class="netbs-renderer position-relative" style="border:1px solid #eee">

    {% include '@NetBSCore/renderer/ajax.frame.twig' with {
        rows: rows,
        headers: headers,
        tableId: tableId,
        page: page,
        amount: amount,
        search: search,
        totalItems: totalItems,
        allIds: allIds,
        listId: listId,
        params: modelParams,
        hasSearch: hasSearch,
    } %}

    {% if toolbar.items|length > 0 %}
    <div class="netbs-toolbar dropup">
        <div class="row pb-3 px-3">
            <div class="col-md-6">
                {% for item in toolbar.items('left') %}
                    {{ item.render()|raw }}
                {% endfor %}
            </div>

            <div class="col-md-6 d-flex justify-content-end">
                {% for item in toolbar.items('right') %}
                    {{ item.render()|raw }}
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

</div>

<script type="text/javascript">
    var {{ tableId }} = {
        getSelectedIds: function() {
            var frameEl = document.getElementById('list-frame-{{ tableId }}');
            if (!frameEl) return [];
            var app = window.Stimulus;
            if (app) {
                var controller = app.getControllerForElementAndIdentifier(frameEl, 'checkbox-select');
                // getSelectedIds() handles the "empty selection → all filtered ids" fallback
                if (controller) return controller.getSelectedIds();
            }
            var checked = frameEl.querySelectorAll('[data-checkbox-select-target="checkbox"]:checked');
            return Array.from(checked).map(function(cb) { return parseInt(cb.value, 10); });
        }
    };
</script>
