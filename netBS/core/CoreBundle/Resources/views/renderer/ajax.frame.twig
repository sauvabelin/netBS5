{#
    Turbo Frame partial for list pagination/search.
    Used by both ajax and netbs renderers. The caller passes `baseUrl`
    to select the correct controller endpoint.

    Variables:
      - rows: array of {id, cells} — the current page of data
      - headers: array of column header strings
      - tableId: unique table identifier
      - page: current page (0-indexed)
      - amount: items per page
      - search: current search string
      - totalItems: total matching items count
      - allIds: all IDs (unfiltered) for checkbox-select
      - listId: the model alias
      - params: model parameters (associative array)
      - hasSearch: whether the model supports search
      - baseUrl: (optional) the endpoint URL for Turbo Frame navigation
#}

{% set frameId = 'list-frame-' ~ tableId %}
{% set totalPages = ((totalItems - 1) / amount)|round(0, 'floor') %}
{% set totalPages = totalPages < 0 ? 0 : totalPages %}
{% set firstItem = page * amount + 1 %}
{% set lastItem = (page * amount + amount) > totalItems ? totalItems : (page * amount + amount) %}
{% set lastItem = totalItems == 0 ? 0 : lastItem %}
{% set firstItem = totalItems == 0 ? 0 : firstItem %}

{# Use passed baseUrl, or default to ajax endpoint #}
{% set baseUrl = baseUrl|default(path('netbs.core.ajax_list_html', { listId: listId })) %}

<turbo-frame id="{{ frameId }}"
    data-controller="checkbox-select ajax-list"
    data-checkbox-select-all-ids-value="{{ allIds|json_encode }}"
    data-ajax-list-base-url-value="{{ baseUrl }}"
    data-ajax-list-params-value="{{ params|length > 0 ? params|json_encode : '{}' }}"
    data-ajax-list-table-id-value="{{ tableId }}"
    data-ajax-list-select2-url-value="{{ path('netbs.core.select2.results') }}"
>
    <div class="position-relative">
        {# Controls: amount + search #}
        <div class="row px-3 pt-3">
            <div class="col-sm-12 col-md-6">
                <div class="dataTables_length">
                    <label class="d-flex align-items-center">
                        Show
                        <select class="form-control form-control-sm mx-1" style="width:75px"
                                data-ajax-list-target="amount"
                                data-action="change->ajax-list#changeAmount">
                            {% for opt in [10, 25, 50, 100] %}
                                <option value="{{ opt }}" {{ amount == opt ? 'selected' : '' }}>{{ opt }}</option>
                            {% endfor %}
                        </select> entries
                    </label>
                </div>
            </div>
            <div class="col-sm-12 col-md-6 d-flex justify-content-end">
                {% if hasSearch %}
                    <div class="dataTables_filter">
                        <label class="d-flex align-items-center">Search:
                            <input type="search" class="ms-1 form-control form-control-sm" placeholder=""
                                   value="{{ search }}"
                                   data-ajax-list-target="search"
                                   data-action="input->ajax-list#searchChanged">
                        </label>
                    </div>
                {% endif %}
            </div>
        </div>

        {# Table #}
        <table id="{{ tableId }}" class="table table-hover table-responsive-md table-striped table-fw-widget" style="margin:0 !important;">
            <thead>
            <tr>
                <th data-orderDataType="checkbox" style="width:30px;">
                    <div class="form-check">
                        <input id="{{ tableId }}_main_cb" class="form-check-input" type="checkbox"
                               data-checkbox-select-target="selectAll"
                               data-action="change->checkbox-select#toggleAll">
                        <label class="form-check-label" for="{{ tableId }}_main_cb"></label>
                    </div>
                </th>
                {% for header in headers %}
                    <th>{{ header }}</th>
                {% endfor %}
            </tr>
            </thead>
            <tbody>
                {% for row in rows %}
                    <tr>
                        <td>
                            <div class="form-check">
                                <input id="{{ tableId }}_cb_{{ row.id }}" class="form-check-input" type="checkbox"
                                       value="{{ row.id }}"
                                       data-checkbox-select-target="checkbox"
                                       data-action="change->checkbox-select#toggle">
                                <label class="form-check-label" for="{{ tableId }}_cb_{{ row.id }}"></label>
                            </div>
                        </td>
                        {% for cell in row.cells %}
                            <td>{{ cell|raw }}</td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {# Pagination info + buttons #}
        <div class="row px-3 pt-3">
            <div class="col-sm-12 col-md-5">
                <div class="dataTables_info">Showing {{ firstItem }} to {{ lastItem }} of {{ totalItems }} entries</div>
            </div>
            <div class="col-sm-12 col-md-7 d-flex justify-content-end">
                <div class="dataTables_paginate paging_simple_numbers">
                    <ul class="pagination">
                        <li class="paginate_button page-item previous {{ page == 0 ? 'disabled' : '' }}">
                            <a href="#" class="page-link" data-action="click->ajax-list#goToPage" data-page="{{ page - 1 }}">Previous</a>
                        </li>

                        {# Page buttons logic — mirrors the Vue computed pageButtons #}
                        {% if totalPages < 5 %}
                            {% for i in 0..totalPages %}
                                <li class="paginate_button page-item {{ i == page ? 'active' : '' }}">
                                    <a href="#" class="page-link" data-action="click->ajax-list#goToPage" data-page="{{ i }}">{{ i + 1 }}</a>
                                </li>
                            {% endfor %}
                        {% elseif page == 0 or page == 1 %}
                            {% for i in [0, 1, 2, totalPages] %}
                                <li class="paginate_button page-item {{ i == page ? 'active' : '' }}">
                                    <a href="#" class="page-link" data-action="click->ajax-list#goToPage" data-page="{{ i }}">{{ i + 1 }}</a>
                                </li>
                            {% endfor %}
                        {% elseif page == totalPages or page == totalPages - 1 %}
                            {% for i in [totalPages - 3, totalPages - 2, totalPages - 1, totalPages] %}
                                <li class="paginate_button page-item {{ i == page ? 'active' : '' }}">
                                    <a href="#" class="page-link" data-action="click->ajax-list#goToPage" data-page="{{ i }}">{{ i + 1 }}</a>
                                </li>
                            {% endfor %}
                        {% else %}
                            {% for i in [0, page - 1, page, page + 1, totalPages] %}
                                <li class="paginate_button page-item {{ i == page ? 'active' : '' }}">
                                    <a href="#" class="page-link" data-action="click->ajax-list#goToPage" data-page="{{ i }}">{{ i + 1 }}</a>
                                </li>
                            {% endfor %}
                        {% endif %}

                        <li class="paginate_button page-item next {{ page == totalPages ? 'disabled' : '' }}">
                            <a href="#" class="page-link" data-action="click->ajax-list#goToPage" data-page="{{ page + 1 }}">Next</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    {# jQuery plugin initialization is handled by the ajax-list Stimulus controller.
       On connect() and on turbo:frame-load, it re-initializes x-editable, select2,
       and modal click handlers inside the table. #}
</turbo-frame>
