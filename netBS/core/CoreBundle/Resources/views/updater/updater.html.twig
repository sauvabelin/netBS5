{% extends '@NetBSCore/layout/backend.layout.twig' %}

{% block wrapperClass %}be-aside{% endblock %}

{% block main %}

    {% set items        = form.children|first %}
    {% set allowAdd     = items.vars.allow_add %}
    {% set allowDelete  = items.vars.allow_delete %}
    {% set _updater_id  = increment() %}
    {% set tableClass   = '' %}
    {% set itemsForm    = (form.children|first).vars.prototype %}

    <div class="d-flex flex-row" data-controller="mass-updater" data-mass-updater-updater-id-value="{{ _updater_id }}" data-mass-updater-skip-fields-value="{{ skipFields|default([])|json_encode }}">

        <aside class="page-aside" style="background:#fcf8e3;">

            <div class="content">

                <div class="aside-head">
                    <h3>Opération en masse</h3>
                    <p class="alert alert-warning">
                        Remplissez les champs ci-dessous puis cliquez sur <b>Appliquer</b> pour pré-remplir tous les éléments du formulaire.
                    </p>
                </div>

                {{ form(generic) }}

                <button type="button" class="btn btn-warning w-100 mt-2" data-action="click->mass-updater#propagateAll">
                    <i class="fas fa-arrow-right me-1"></i> Appliquer à tous
                </button>

            </div>

        </aside>

        <div class="p-10" style="background:white;">

            {% if allowAdd %}
                <table id="mass-prototype-{{ _updater_id }}" style="display:none;">
                    <tr>
                        {% for protofield in items.vars.prototype.children %}
                            <td>
                                {{ form_widget(protofield) }}
                                {{ form_errors(protofield) }}
                            </td>
                        {% endfor %}
                        {% if allowDelete %}
                            <td>
                                <button class="btn btn-rounded btn-space btn-secondary" type="button" data-delete-element-{{ _updater_id }}><i class="fas fa-times fa-sm"></i></button>
                            </td>
                        {% endif %}
                    </tr>
                </table>
            {% endif %}

            <div class="panel panel-table">

                <div style="padding:20px">
                    <h3>{{ title }}</h3>
                </div>

                {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
                <input type="hidden" name="_return_url" value="{{ returnUrl|default('') }}">

                {% include '@NetBSCore/updater/updater.partial.twig' %}

                <div class="text-end" style="padding:20px;border-top:1px solid #ccc;">
                    {% if allowAdd %}
                        <button class="btn btn-secondary btn-space" type="button" data-action="click->mass-updater#addRow">Ajouter une ligne</button>
                    {% endif %}
                    <button class="btn btn-primary btn-space">Valider</button>
                </div>

                <div style="display:none;">
                    {{ form_rest(form) }}
                </div>
                {{ form_end(form) }}
            </div>
        </div>

    </div>

{% endblock %}
