<script type="text/javascript">

    function triggerMassDeleteListener(id) {
        document.querySelectorAll('[data-delete-element-' + id + ']').forEach(function(btn) {
            btn.addEventListener('click', function() {
                this.closest('tr').remove();
            });
        });
    }

</script>

<script type="text/javascript">
    document.addEventListener('DOMContentLoaded', function() {
        triggerMassDeleteListener('{{ _updater_id }}');
    });
</script>
