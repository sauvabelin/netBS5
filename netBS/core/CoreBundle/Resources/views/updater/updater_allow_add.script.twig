{% set newItemPrototype %}
    <table id="mass-prototype-{{ _updater_id }}" style="display:none;">
        <tr>
            {% for protofield in items.vars.prototype.children %}
                <td>
                    {{ form_widget(protofield) }}
                    {{ form_errors(protofield) }}
                </td>
            {% endfor %}
            {% if allowDelete %}
                <td>
                    <button class="btn btn-rounded btn-space btn-secondary" type="button" data-delete-element-{{ _updater_id }}><i class="fas fa-times fa-sm"></i></button>
                </td>
            {% endif %}
        </tr>
    </table>
{% endset %}

{{ registerHtml(newItemPrototype) }}

<script type="text/javascript">
    function onAddClick(id, allowDelete) {
        var tbody = document.getElementById('mass-items-table-' + id).querySelector('tbody');
        var row   = document.getElementById('mass-prototype-' + id).querySelector('tr').cloneNode(true);
        var count = tbody.querySelectorAll('tr').length;

        row.querySelectorAll('td').forEach(function(td) {
            var sub = td.querySelector('input, select, textarea');
            if (!sub) return;
            var subId   = sub.getAttribute('id'),
                subName = sub.getAttribute('name');
            if (subId) sub.setAttribute('id', subId.replace('__name__', count));
            if (subName) sub.setAttribute('name', subName.replace('__name__', count));
        });

        tbody.appendChild(row);
        if (allowDelete) triggerMassDeleteListener(id);
    }

    var addBtn = document.querySelector('[data-mass-add-{{ _updater_id }}]');
    if (addBtn) {
        addBtn.addEventListener('click', function() {
            onAddClick('{{ _updater_id }}', {{ allowDelete }});
        });
    }
</script>
