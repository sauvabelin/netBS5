<script type="text/javascript">
    (function() {

        {# generic form handling #}
        {% for genericItem in generic.children %}

            {% set prefix   = genericItem.vars.block_prefixes %}
            {% set name     = genericItem.vars.name %}

            document.getElementById('{{ genericItem.vars.id }}').addEventListener('change', function() {

                {# AJAX SELECT2 #}
                {% if 'ajax_select2_document' in prefix %}

                var selectedValues = Array.from(this.selectedOptions).map(function(opt) { return opt.value; });
                document.querySelectorAll('[name$="][{{ name }}]"]').forEach(function(el) {
                    el.innerHTML = '';
                    Array.from(this.selectedOptions).forEach(function(opt) {
                        var newOpt = new Option(opt.text, opt.value, true, true);
                        el.appendChild(newOpt);
                    });
                    el.value = this.value;
                    el.dispatchEvent(new Event('change'));
                }.bind(this));

                {# SELECT2 #}
                {% elseif 'select2_document' in prefix %}
                document.querySelectorAll('[name$="][{{ name }}]"]').forEach(function(el) {
                    el.value = this.value;
                    el.dispatchEvent(new Event('change'));
                }.bind(this));

                {# DATEPICKER #}
                {% elseif 'datepicker' in prefix %}
                document.querySelectorAll('[name$="][{{ name }}]"]').forEach(function(el) {
                    el.value = this.value;
                }.bind(this));

                {# OTHER #}
                {% else %}
                document.querySelectorAll('[name$="][{{ name }}]"]').forEach(function(el) {
                    el.value = this.value;
                }.bind(this));
                {% endif %}

            });

        {% endfor %}

    })();
</script>
