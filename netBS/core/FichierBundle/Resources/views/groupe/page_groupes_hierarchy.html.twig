{% extends '@NetBSCore/layout/backend.layout.twig' %}

{% block main %}

    {{ registerJs(asset('bundles/netbscore/js/modal.js')) }}
    {% set newGroupeBtn %}<button data-controller="modal" data-modal-url-value="{{ path("netbs.fichier.groupe.modal_add") }}" data-action="click->modal#open" class="btn btn-primary">Nouvelle unité</button>{% endset %}

    <div class="container-fluid">

        {% include '@NetBSCore/includes/header.include.twig' with {
            header: 'Liste des unités',
            subHeader: 'Toutes les unités et sous-unités enregistrées',
            actions: [
                newGroupeBtn
            ]
        } %}

        <div id="groupes-app" data-controller="group-filter">

            <div class="row">
                <div class="col-sm-1 col-12">
                    Par nom
                </div>
                <div class="col-lg-2 col-md-3 col-sm-6 col-12">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" placeholder="Rechercher par nom"
                               data-group-filter-target="searchInput"
                               data-action="input->group-filter#search" />
                    </div>
                </div>

            </div>

            <div class="row">
                <div class="col-sm-1 col-12">
                    Categories
                </div>

                <div class="col-sm-11 col-12">
                    <div class="btn-group" role="group">
                        {% for categorie in categories %}
                            <button type="button" class="btn btn-secondary"
                                    data-action="click->group-filter#toggleCategory"
                                    data-group-filter-category-param="{{ categorie.nom }}">{{ categorie.nom }}</button>
                        {% endfor %}
                    </div>
                </div>

            </div>

            <br/>

            <div class="row">
                <div class="col-sm-1 col-12">
                    Types
                </div>
                <div class="col-sm-11 col-12">
                    <div class="btn-group" role="group">
                        {% for type in types %}
                            {% if type.nom not in categories|map(c => c.nom) %}
                                <button type="button" class="btn btn-secondary"
                                        data-action="click->group-filter#toggleType"
                                        data-group-filter-type-param="{{ type.nom }}">{{ type.nom }}</button>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>

            </div>

            <hr/>

            <div class="row">
                {% for groupe in groupes %}
                    <div class="col-lg-3 col-md-4 col-sm-4 col-6"
                         data-group-filter-target="group"
                         data-group-name="{{ groupe.nom }}{% if groupe.groupeType.affichageEffectifs and groupe.parent %} ({{ groupe.parent.nom }}){% endif %}"
                         data-group-type="{{ groupe.groupeType.nom }}"
                         data-group-category="{{ groupe.groupeType.groupeCategorie.nom }}">
                        <a class="card" href="{{ path('netbs.fichier.groupe.page_groupe', {id: groupe.id}) }}">
                            <div class="card-header">
                                <h3 class="card-title">{{ groupe.nom }}{% if groupe.groupeType.affichageEffectifs and groupe.parent %} ({{ groupe.parent.nom }}){% endif %}</h3>
                                <h5 class="card-subtitle">{{ groupe.groupeType.nom }}{% if groupe.groupeType.nom not in categories|map(c => c.nom) %} - {{ groupe.groupeType.groupeCategorie.nom }}{% endif %}</h5>
                            </div>
                        </a>
                    </div>
                {% endfor %}
            </div>

        </div>

    </div>

{% endblock %}