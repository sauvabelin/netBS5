
{% if form.telephones|length > 0 %}
    <table class="table table-condensed table-bordered">
        <thead>
        <tr>
            <th>Numéro</th>
            <th>Prioritaire</th>
            <th>Remarques</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        {% for telephone in form.telephones %}
            <tr>
                <td>{{ form_widget(telephone.telephone) }}</td>
                <td>{{ form_widget(telephone.expediable) }}</td>
                <td>{{ form_widget(telephone.remarques) }}</td>
                <td>
                    <a class="btn btn-danger btn-xs"
                       href="{{ path('netbs.fichier.telephone.delete', {ownerId: item.id, ownerType: get_class(item)|toBase64, telephoneId: telephone.vars.data.id}) }}"
                       data-turbo-confirm="Etes-vous sûr de supprimer ce numéro ?"><i class="fas fa-times fa-sm"></i></a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% else %}
    <p class="text-muted">Aucun numéro de téléphone enregistré</p>
{% endif %}

<button class="btn btn-space btn-primary"
        data-controller="modal" data-modal-url-value="{{ path('netbs.fichier.telephone.modal_creation', {ownerId: item.id, ownerType: get_class(item)|toBase64}) }}" data-action="click->modal#open">Nouveau numéro</button>